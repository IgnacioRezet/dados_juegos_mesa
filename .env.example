# Persistencia de hojas de personaje (opcional).
# Si NO defines estas variables, la mesa funciona en modo solo memoria:
# las hojas viven mientras la sesión tenga jugadores y no se guardan.

# URL del Strapi independiente (proyecto en C:\Proyectos-propios\tor-strapi)
STRAPI_URL=http://localhost:1337

# API Token creado en Strapi (Settings → API Tokens) con permisos
# find/findOne/create/update sobre el content-type character-sheet.
STRAPI_TOKEN=

# (Opcional) plural API id del content-type, por si lo renombras.
# STRAPI_COLLECTION=character-sheets

# Puerto del servidor de la mesa (por defecto 3000)
# PORT=3000
